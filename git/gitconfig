# vim: ft=gitconfig

[user]
	name = tonic
	email = tonicbupt@gmail.com

[alias]
	st = status
	co = checkout
	wtf = "!git commit -m\"$(curl -L -s https://commitlog.wolege.ca/)"\"

[pager]
	diff =
	branch = false

[core]
	editor = nvim
	excludesfile = ~/.gitignore

[help]
	autocorrect = 1

[color]
	ui = true

[push]
	default = current

[include]
	path = ~/.gitconfig.local
